#usda 1.0
(
    defaultPrim = "World"
    metersPerUnit = 1
    upAxis = "Z"
)

def Xform "World"
{
    def PhysicsScene "PhysicsScene"
    {
        float3 physics:gravityDirection = (0, 0, -1)
        float physics:gravityMagnitude = 9.81
    }

    def Xform "JointTest" (
        prepend apiSchemas = ["PhysicsArticulationRootAPI"]
    )
    {
        def Xform "Visuals"
        {
            def Xform "Chest"
            {
                float3 xformOp:rotateXYZ = (180, 0, 0)
                float3 xformOp:scale = (0.001, 0.001, 0.001)
                uniform token[] xformOpOrder = ["xformOp:rotateXYZ", "xformOp:scale"]

                def Xform "Mesh" (
                    references = @./assets/usd/chest.usd@
                )
                {
                }
            }

            def Xform "RightShoulderSupport"
            {
                float3 xformOp:rotateXYZ = (180, 0, 0)
                float3 xformOp:scale = (0.001, 0.001, 0.001)
                uniform token[] xformOpOrder = ["xformOp:rotateXYZ", "xformOp:scale"]

                def Xform "shoulder_support_bottom" (
                    references = @./assets/usd/shoulder_support_bottom.usd@
                )
                {
                }

                def Xform "shoulder_support_top" (
                    references = @./assets/usd/shoulder_support_top.usd@
                )
                {
                }

                def Xform "pitch_holder" (
                    references = @./assets/usd/pitch_holder.usd@
                )
                {
                }

                def Xform "shoulder_pitch_servo_s85" (
                    references = @./assets/usd/shoulder_pitch_servo_s85.usd@
                )
                {
                }
            }
        }

        def Xform "ChestBody" (
            prepend apiSchemas = ["PhysicsRigidBodyAPI", "PhysicsMassAPI"]
        )
        {
            float physics:mass = 1

            def Xform "Colliders"
            {
                def Cube "Chest" (
                    prepend apiSchemas = ["PhysicsCollisionAPI"]
                )
                {
                    token visibility = "invisible"
                    double size = 1
                    float3 xformOp:scale = (0.13014, 0.2, 0.14951)
                    float3 xformOp:translate = (0, 0.100275, -0.106247)
                    uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
                }
            }
        }

        def Xform "ShoulderPitchChildBody" (
            prepend apiSchemas = ["PhysicsRigidBodyAPI", "PhysicsMassAPI"]
        )
        {
            float physics:mass = 0.5
            float3 xformOp:translate = (0.22, 0, 0.24)
            uniform token[] xformOpOrder = ["xformOp:translate"]

            def Xform "Visuals"
            {
                float3 xformOp:rotateXYZ = (180, 0, 0)
                float3 xformOp:scale = (0.001, 0.001, 0.001)
                uniform token[] xformOpOrder = ["xformOp:rotateXYZ", "xformOp:scale"]

                def Xform "ShoulderPitch"
                {
                    def Xform "pitch_roller_clip_bottom" (
                        references = @./assets/usd/pitch_roller_clip_bottom_visual.usd@
                    )
                    {
                    }

                    def Xform "pitch_roller_clip_left_side" (
                        references = @./assets/usd/pitch_roller_clip_left_side_visual.usd@
                    )
                    {
                    }

                    def Xform "pitch_roller_clip_right_side" (
                        references = @./assets/usd/pitch_roller_clip_right_side_visual.usd@
                    )
                    {
                    }

                    def Xform "pitch_roller_clip_up" (
                        references = @./assets/usd/pitch_roller_clip_up_visual.usd@
                    )
                    {
                    }
                }

                def Xform "ShoulderYaw"
                {
                    def Xform "shoulder_yaw_servo_sts3215" (
                        references = @./assets/usd/shoulder_yaw_servo_sts3215_visual.usd@
                    )
                    {
                    }

                    def Xform "shoulder_yaw" (
                        references = @./assets/usd/shoulder_yaw_visual.usd@
                    )
                    {
                    }
                }

                def Xform "UpperArm"
                {
                    def Xform "humreal_up_fixed" (
                        references = @./assets/usd/humreal_up_fixed_visual.usd@
                    )
                    {
                    }

                    def Xform "humreal_down" (
                        references = @./assets/usd/humreal_down_visual.usd@
                    )
                    {
                    }
                }
            }

            def Xform "Colliders"
            {
                def Cube "ShoulderPitchChild" (
                    prepend apiSchemas = ["PhysicsCollisionAPI"]
                )
                {
                    token visibility = "invisible"
                    double size = 0.14
                    float3 xformOp:scale = (0.7, 0.7, 1.8)
                    float3 xformOp:translate = (0.08, 0, 0)
                    uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
                }
            }
        }

        def PhysicsFixedJoint "world_to_chest"
        {
            rel physics:body1 = </World/JointTest/ChestBody>
            point3f physics:localPos0 = (0, 0.100275, -0.106247)
            point3f physics:localPos1 = (0, 0.100275, -0.106247)
            quatf physics:localRot0 = (1, 0, 0, 0)
            quatf physics:localRot1 = (1, 0, 0, 0)
        }

        def PhysicsRevoluteJoint "right_shoulder_pitch" (
            prepend apiSchemas = ["PhysicsDriveAPI:angular"]
        )
        {
            uniform token axis = "Y"
            float drive:angular:physics:damping = 5
            float drive:angular:physics:stiffness = 20
            float drive:angular:physics:targetPosition = 0
            float physics:lowerLimit = -60
            float physics:upperLimit = 60
            rel physics:body0 = </World/JointTest/ChestBody>
            rel physics:body1 = </World/JointTest/ShoulderPitchChildBody>
            point3f physics:localPos0 = (0.06507, 0.000275, -0.031492)
            point3f physics:localPos1 = (0, 0, 0)
            quatf physics:localRot0 = (1, 0, 0, 0)
            quatf physics:localRot1 = (1, 0, 0, 0)
        }
    }
}
