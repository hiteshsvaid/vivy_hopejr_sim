            }

            def Xform "UpperArm"
            {
                def Xform "humreal_up_fixed" (references = @./assets/usd/humreal_up_fixed.usd@) {}
                def Xform "humreal_down" (references = @./assets/usd/humreal_down.usd@) {}
            }

            def Xform "Elbow"
            {
                def Xform "elbow_servo_sts3215" (references = @./assets/usd/elbow_servo_sts3215.usd@) {}
                def Xform "upper_elbow_roll_servo_sts3215" (references = @./assets/usd/upper_elbow_roll_servo_sts3215.usd@) {}
