                def Xform "lower_elbow_outer" (references = @./assets/usd/lower_elbow_outer.usd@) {}
                def Xform "lower_elbow_side_l" (references = @./assets/usd/lower_elbow_side_l.usd@) {}
                def Xform "lower_elbow_side_r" (references = @./assets/usd/lower_elbow_side_r.usd@) {}
                def Xform "lower_elbow_roll_servo_sts3215" (references = @./assets/usd/lower_elbow_roll_servo_sts3215.usd@) {}
            }

            def Xform "Forearm"
            {
                def Xform "forearm_front" (references = @./assets/usd/forearm_front.usd@) {}
                def Xform "forearm_back" (references = @./assets/usd/forearm_back.usd@) {}
