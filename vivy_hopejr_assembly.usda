#usda 1.0
(
    defaultPrim = "World"
    metersPerUnit = 1
    upAxis = "Z"
)

def Xform "World"
{
    def Xform "HopeJrRightArm"
    {
        float3 xformOp:rotateXYZ = (180, 0, 0)
        uniform token[] xformOpOrder = ["xformOp:rotateXYZ"]

        def Xform "Visuals"
        {
            def Xform "Chest"
            {
                def Xform "chest" (references = @./assets/usd/chest.usd@) {}
            }

            def Xform "ShoulderSupport"
            {
                def Xform "shoulder_support_bottom" (references = @./assets/usd/shoulder_support_bottom.usd@) {}
